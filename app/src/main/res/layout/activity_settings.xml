<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 최대 고객 거리 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="최대 고객 거리"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/airport_distance_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="최대 고객 거리: 5.0 km"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/airport_distance_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp" />

        <!-- 수락 조건 섹션 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="수락 조건"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="체크된 조건 중 하나라도 만족하면 콜을 수락합니다"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/condition1_checkbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="조건 1: 출발지(서울/특별시) → 도착지(인천공항)"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  └ 서울에서 출발해 인천공항으로 가는 콜"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginBottom="10dp" />

        <CheckBox
            android:id="@+id/condition2_checkbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="조건 2: 출발지(인천공항) → 도착지(어디든)"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  └ 인천공항에서 출발하는 모든 콜"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginBottom="10dp" />

        <CheckBox
            android:id="@+id/condition3_checkbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="조건 3: 출발지(광역시) → 도착지(서울/특별시)"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  └ 부산·대구 등 광역시에서 서울로 가는 콜"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginBottom="10dp" />

        <CheckBox
            android:id="@+id/condition4_checkbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="조건 4: 출발지(어디든) → 도착지(인천공항)"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  └ 출발지 무관, 인천공항으로 가는 모든 콜"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginBottom="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp" />

        <!-- 출발지 키워드 섹션 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="출발지 키워드"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="조건1: 출발지에 아래 키워드 중 하나 포함 → 공항행 콜 수락\n(탭하면 삭제)"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/pickup_keywords_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/pickup_keyword_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="키워드 입력 (예: 경기도)"
                android:inputType="text"
                android:imeOptions="actionDone"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/add_pickup_keyword_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="추가" />

        </LinearLayout>

        <!-- 원격 로깅 섹션 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="원격 로깅"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="원격 로깅 활성화"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/remote_logging_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <Button
            android:id="@+id/save_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="저장"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <!-- 앱 정보 섹션 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="앱 정보"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/app_version_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="앱 버전: -"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/shizuku_status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Shizuku: -"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/check_update_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="업데이트 확인"
            android:textSize="14sp" />

    </LinearLayout>

</ScrollView>
