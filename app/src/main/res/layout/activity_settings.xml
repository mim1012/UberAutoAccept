<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 최대 고객 거리 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="최대 고객 거리"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/airport_distance_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="최대 고객 거리: 5.0 km"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/airport_distance_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp" />

        <!-- 수락 조건 섹션 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="수락 조건"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="하나의 조건을 선택하세요"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="12dp" />

        <RadioGroup
            android:id="@+id/condition_radio_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/condition1_radio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="서울출발 → 공항 또는 서울행"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <RadioButton
                android:id="@+id/condition2_radio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="인천공항출발 → 어디든"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <RadioButton
                android:id="@+id/condition3_radio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="광역시출발 → 특별시행"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <RadioButton
                android:id="@+id/condition4_radio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="어디서든 → 인천공항행"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <RadioButton
                android:id="@+id/condition5_radio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="특별시출발 → 광역시행"
                android:textSize="14sp" />

        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp" />

        <!-- 원격 로깅 섹션 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="원격 로깅"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="원격 로깅 활성화"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/remote_logging_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <Button
            android:id="@+id/save_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="저장"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <!-- 앱 정보 섹션 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="앱 정보"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/app_version_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="앱 버전: -"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/shizuku_status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Shizuku: -"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/check_update_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="업데이트 확인"
            android:textSize="14sp" />

    </LinearLayout>

</ScrollView>
