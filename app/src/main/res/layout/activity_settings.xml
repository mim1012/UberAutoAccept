<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="필터링 모드"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/mode_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp" />

        <!-- 시나리오 1: 서울 출발 → 인천공항 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="서울 출발 → 인천공항 (고객 거리)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/seoul_distance_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="최대 고객 거리: 3.0 km"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/seoul_distance_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp" />

        <!-- 시나리오 2: 인천공항 출발 → 전체 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="인천공항 출발 → 모든 콜 (고객 거리)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/airport_distance_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="최대 고객 거리: 7.0 km"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/airport_distance_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp" />

        <!-- 원격 로깅 섹션 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="원격 로깅"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="원격 로깅 활성화"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/remote_logging_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="서버 URL"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/server_url_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="http://your-server.com"
            android:inputType="textUri"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/test_connection_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="연결 테스트"
            android:textSize="14sp"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/save_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="저장"
            android:textSize="16sp" />

    </LinearLayout>

</ScrollView>
